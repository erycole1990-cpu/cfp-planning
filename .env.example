# Supabase - get from your project dashboard under Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=false

# Server-side only - NEVER expose these values to the browser
OPENAI_API_KEY=
RESEND_API_KEY=
NOTIFICATION_FROM_EMAIL=CFP Planning <onboarding@resend.dev>

# Stripe
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_

# Webhook secret - from Stripe dashboard under Webhooks > your endpoint
# For local dev: stripe listen --forward-to localhost:3000/api/stripe/webhooks
STRIPE_WEBHOOK_SECRET=whsec_

# Your price IDs from Stripe dashboard under Products
NEXT_PUBLIC_STRIPE_PRICE_MONTHLY=price_
NEXT_PUBLIC_STRIPE_PRICE_YEARLY=price_

# Stripe Connect (set by Vibe Launchpad when provisioned via platform)
# Leave blank if running standalone with your own Stripe account
STRIPE_CONNECT_ACCOUNT_ID=
STRIPE_PLATFORM_FEE_PERCENT=

# App URL (used for redirect URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000
